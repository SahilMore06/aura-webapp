# AURA — Backend Environment Variables
# Place in: AQI FINAL/backend/.env
# Never commit this file to git.

# ── Supabase (Service Role — server-side only, NEVER expose to frontend) ──
SUPABASE_URL=https://mnzmwhgrzhiemhgukwjk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Resend (Email Service) ────────────────────────────────────────────────
# Get free API key at: https://resend.com
RESEND_API_KEY=re_your_api_key_here
# Must be a verified domain in Resend: https://resend.com/domains
RESEND_FROM_EMAIL=AURA Air Quality <otp@yourdomain.com>

# ── Flask ─────────────────────────────────────────────────────────────────
PORT=5001
FLASK_ENV=development
CORS_ORIGINS=http://localhost:3000
