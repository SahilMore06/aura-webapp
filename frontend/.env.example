# AURA — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.

# ─── Supabase ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Google Air Quality API ───────────────────────────────────
# https://console.cloud.google.com → Enable "Air Quality API"
VITE_GOOGLE_AQ_API_KEY=your-google-aq-api-key

# ─── ML Backend URL ──────────────────────────────────────────
# Development: http://localhost:5001
# Production:  https://aura-ml-api.onrender.com  (or your Render URL)
VITE_ML_API_URL=https://aura-ml-api.onrender.com
